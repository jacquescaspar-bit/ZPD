# ZPD Learning - Environment Variables Example
# Copy this file to .env.local and fill in your actual values.
# Never commit .env.local or real secrets.

# =============================================================================
# DATABASE (required for enrollments, referrals, sessions, analytics)
# Use PostgreSQL. For local: install Postgres or use Docker/Supabase local.
# Example for local Postgres: postgresql://postgres:password@localhost:5432/zpd
# For production: use managed Postgres (Supabase, Neon, Railway, etc.)
# =============================================================================
DATABASE_URL=postgresql://username:password@localhost:5432/zpd_db

# =============================================================================
# STRIPE (required to enable real card payments)
# Get these from https://dashboard.stripe.com/test/apikeys (use TEST keys for local dev)
# For production use LIVE keys (pk_live_..., sk_live_...)
#
# LOCAL DEV WEBHOOK SETUP (strongly recommended):
# 1. Install Stripe CLI: https://stripe.com/docs/stripe-cli
# 2. Run: stripe login
# 3. Run: stripe listen --forward-to http://localhost:3000/api/webhooks/stripe
# 4. Copy the "whsec_..." value from the CLI output into STRIPE_WEBHOOK_SECRET below
#    (this is the local testing secret; dashboard one is only for deployed URL)
#
# PRODUCTION:
# - Set up webhook in Stripe Dashboard -> Webhooks
# - Endpoint URL: https://zpdlearning.com/api/webhooks/stripe
# - Events: payment_intent.succeeded (and optionally payment_intent.payment_failed)
# - Copy the "Signing secret" (starts with whsec_) to STRIPE_WEBHOOK_SECRET
# =============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# =============================================================================
# EMAIL (SendGrid - required for sending referral codes and propagation emails)
# Sign up at https://sendgrid.com (free tier available)
# Create API key with "Full Access" or Mail Send permissions
# Verify a sender identity (single sender or domain)
# =============================================================================
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
FROM_EMAIL=grow@zpdlearning.com
# 2FA recovery codes (Vercel, SendGrid, etc.) → secrets/recovery-codes.md — not here

# =============================================================================
# OPTIONAL
# =============================================================================

# Local dev: payment confirmation emails link to localhost (not zpdlearning.com)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin email for notifications (used in insights submission)
ADMIN_EMAIL=grow@zpdlearning.com

# Admin console password (required in production for /admin access)
ADMIN_PASSWORD=your-secure-admin-password-here

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Vercel Blob (insights document uploads — private zpd-blob store)
# Without BLOB_READ_WRITE_TOKEN, local dev stores uploads under .data/uploads/insights/
# Connect your Blob store to the Vercel project to get these values.
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=

# Cron auth for POST /api/cron/nurture (abandoned enrolment + insights reminders)
CRON_SECRET=your-random-cron-secret

# Optional: dedicated secret for enrollment session resume tokens (falls back to CRON_SECRET, then ADMIN_PASSWORD)
# ENROLLMENT_SESSION_SECRET=your-random-enrollment-session-secret
